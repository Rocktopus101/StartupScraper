# ============================================
# StartupScraper — API Keys
# ============================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control!

# Serper API — Google search with dorking support
# Only required if engine: "serper" in config.yaml
# Get your free key (2,500 searches): https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# Resend — Email delivery service
# Get your free key (100 emails/day): https://resend.com
# Only required if output.mode is "email" or "both"
RESEND_API_KEY=your_resend_api_key_here

# Sender email address
# Use onboarding@resend.dev for testing, or your verified domain
RESEND_FROM_EMAIL=onboarding@resend.dev
